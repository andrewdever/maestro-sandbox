# =============================================================================
# Maestro Sandbox — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# Only E2B_API_KEY is required for cloud sandboxing. All other features
# work without any environment variables.

# --- Cloud Sandbox (Tier 3: E2B) ---
# Required only if using the E2B plugin for cloud micro-VMs.
# Get your key at https://e2b.dev
# E2B_API_KEY=e2b_...

# --- OpenTelemetry (optional) ---
# If you have an OTel collector, the audit logger can emit spans.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=maestro-sandbox
